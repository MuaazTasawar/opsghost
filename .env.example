# GitHub App Credentials
# Create a GitHub App at https://github.com/settings/apps/new
# Set webhook URL to your Render deployment URL + /webhook
GITHUB_APP_ID=                        # TODO: Your GitHub App's numeric ID
GITHUB_APP_PRIVATE_KEY_PATH=private-key.pem   # TODO: Path to downloaded .pem file
GITHUB_WEBHOOK_SECRET=                # TODO: Secret string you set in GitHub App settings

# Groq API (free at https://console.groq.com)
GROQ_API_KEY=                         # TODO: Your Groq API key

# Agent Config
LLM_MODEL=llama-3.3-70b-versatile    # Groq free-tier model
MAX_LOG_CHARS=12000                   # Truncate logs to stay within context window
PR_BRANCH_PREFIX=opsghost/fix         # Prefix for auto-fix branches

# App
PORT=8000
ENVIRONMENT=development               # development | production